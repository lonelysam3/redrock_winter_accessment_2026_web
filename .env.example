# 将此文件复制为 .env 并填写真实值。切勿将 .env 提交到版本控制！
# Copy this file to .env and fill in real values. Never commit .env to version control!

# ─── Web 应用端口 ────────────────────────────────────────────────────────────
APP_PORT=8080

# ─── phpMyAdmin 端口 ─────────────────────────────────────────────────────────
PMA_PORT=8081

# ─── 数据库连接（web 服务使用） ──────────────────────────────────────────────
DB_HOST=db
DB_NAME=shopping_db
DB_USER=shopping_user
DB_PASSWORD=change_me_to_a_strong_password

# ─── MySQL 服务配置 ──────────────────────────────────────────────────────────
# Root 密码：仅用于 phpMyAdmin 和运维操作，请使用高强度随机密码
MYSQL_ROOT_PASSWORD=change_me_to_a_strong_root_password
MYSQL_DATABASE=shopping_db
MYSQL_USER=shopping_user
MYSQL_PASSWORD=change_me_to_a_strong_password
